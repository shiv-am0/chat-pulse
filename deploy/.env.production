# ── Django ──────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=generate-a-random-64-char-key
DEBUG=False
ALLOWED_HOSTS=api.chatpulse.online,localhost
CORS_ALLOWED_ORIGINS=https://chatpulse.online
CSRF_TRUSTED_ORIGINS=https://chatpulse.online

# ── PostgreSQL (Neon free tier or self-hosted) ───────
DB_NAME=chatpulse
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_HOST=your-neon-hostname.neon.tech
DB_PORT=5432
CONN_MAX_AGE=60

# ── Redis (Upstash free tier or self-hosted) ─────────
REDIS_URL=rediss://default:password@your-upstash-hostname.upstash.io:6379

# ── Kafka (Confluent Cloud free tier or self-hosted) ─
KAFKA_BROKER=your-cluster.confluent.cloud:9092
KAFKA_CHAT_TOPIC=chat-messages

# ── Gunicorn ─────────────────────────────────────────
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# ── HTTPS / Security ─────────────────────────────────
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
